{
  "name": "mcp-feishu-doc",
  "version": "2.6.1",
  "mcpName": "mcp-feishu-doc",
  "description": "A Model Context Protocol (MCP) server for Feishu (Lark) cloud document and wiki management. Supports OAuth, Markdown upload, document reading/updating/deleting, search, and multi-app configuration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "mcp-feishu-doc": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.19.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hbin-Zhuang/mcp-feishu-doc.git"
  },
  "bugs": {
    "url": "https://github.com/Hbin-Zhuang/mcp-feishu-doc/issues"
  },
  "homepage": "https://github.com/Hbin-Zhuang/mcp-feishu-doc#readme",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "deploy:dev": "MCP_TRANSPORT_TYPE=http pnpm dlx wrangler dev",
    "deploy:prod": "MCP_TRANSPORT_TYPE=http pnpm dlx wrangler deploy",
    "start": "node ./dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node ./dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=stdio tsx watch src/index.ts",
    "dev:http": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=http tsx watch src/index.ts",
    "rebuild": "pnpm clean && pnpm build",
    "clean": "rimraf dist",
    "docs:generate": "pnpm exec typedoc",
    "depcheck": "pnpm exec depcheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --project tsconfig.scripts.json --noEmit",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "prepare": "husky",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "upload:tech-sharing": "tsx scripts/upload-tech-sharing.ts"
  },
  "pnpm": {
    "overrides": {}
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251212.0",
    "@eslint/js": "^9.39.1",
    "@hono/mcp": "^0.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/validator": "13.15.10",
    "@vitest/coverage-v8": "4.0.18",
    "depcheck": "^1.4.7",
    "diff": "^8.0.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "repomix": "^1.10.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.49.0",
    "vite": "7.2.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "feishu",
    "lark",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "typescript",
    "wiki",
    "document",
    "markdown",
    "oauth"
  ],
  "author": "Hbin-Zhuang (https://github.com/Hbin-Zhuang)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "depcheck": {
    "ignores": [
      "repomix",
      "mcp-feishu-doc"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.2",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation-pino": "^0.55.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@supabase/supabase-js": "^2.87.1",
    "chrono-node": "^2.9.0",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.3",
    "hono": "^4.10.8",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "partial-json": "^0.1.7",
    "pdf-lib": "^1.17.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.0",
    "surrealdb": "^1.3.2",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0",
    "unpdf": "^1.4.0",
    "validator": "13.15.23",
    "zod": "^4.1.13"
  }
}
